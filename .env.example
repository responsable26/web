# =====================================================================
# Variables de entorno de la función serverless api/contacto.js
# ---------------------------------------------------------------------
# NO pongas los valores reales aquí. Este archivo solo documenta qué
# variables hacen falta. Los valores reales se configuran en Vercel
# (Project → Settings → Environment Variables) y NO se versionan.
# =====================================================================

# Clave de API de Resend. Se genera en https://resend.com/api-keys
# Empieza por "re_". Solo vive en el servidor; nunca se expone al cliente.
RESEND_API_KEY=re_tu_clave_de_resend

# Los destinatarios del formulario (campo "to") están HARDCODEADOS en
# api/contacto.js (constante TO). No hay variable de entorno para ellos.
